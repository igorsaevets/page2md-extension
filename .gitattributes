# Normalize line endings to LF in the repo. Windows dev boxes still get CRLF on
# checkout via core.autocrlf; Ubuntu CI checkouts stay LF so bash scripts in
# workflows never see \r.
* text=auto eol=lf

# Explicit binary — never CRLF-mangled or diffed as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
